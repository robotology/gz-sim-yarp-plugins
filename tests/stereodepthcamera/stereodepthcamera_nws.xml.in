<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE robot PUBLIC "-//YARP//DTD yarprobotinterface 3.0//EN" "http://www.yarp.it/DTD/yarprobotinterfaceV3.0.dtd">

<robot name="stereodepthcamera" portprefix="stereodepthcamera" build="0">
    <devices>
        <device name="stereodepthcamera_left_nws" type="@DEPTH_CAMERA_DEVICE_NAME@">
            <param name="name"> /stereodepthcamera/left </param>
            <param name="period"> 0.033333 </param>
            <action phase="startup" level="5" type="attach">
                <param name="device"> stereodepthcamera_left_plugin_device </param>
            </action>
            <action phase="shutdown" level="5" type="detach" />
        </device>
        <device name="stereodepthcamera_right_nws" type="@DEPTH_CAMERA_DEVICE_NAME@">
            <param name="name"> /stereodepthcamera/right </param>
            <param name="period"> 0.033333 </param>
            <action phase="startup" level="5" type="attach">
                <param name="device"> stereodepthcamera_right_plugin_device </param>
            </action>
            <action phase="shutdown" level="5" type="detach" />
        </device>
    </devices>
</robot>
